# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py

# Database
DATABASE_URL=sqlite:///ielts.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/ielts_db

# JWT Secret
JWT_SECRET_KEY=your_secret_key_here_change_in_production

# Cloudinary (for audio storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Login approval flow
# Set to true ONLY when SMTP is fully configured below, otherwise login will 500
REQUIRE_LOGIN_APPROVAL=false
ADMIN_APPROVER_EMAIL=srsurajith@gmail.com
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000

# SMTP (optional, used to send approval and plan-selection mails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=IELTS Platform <your_email@gmail.com>
