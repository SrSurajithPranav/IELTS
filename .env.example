# ── Flask ──────────────────────────────────────────────────────────────────────
# Set to "production" on Render, "development" locally
FLASK_ENV=development
FLASK_APP=wsgi.py

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (development):
DATABASE_URL=sqlite:///ielts.db
# Supabase PostgreSQL (production) – get from Supabase → Settings → Database:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_secret_key_here_change_in_production

# ── Cloudinary (media uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Login approval flow ────────────────────────────────────────────────────────
REQUIRE_LOGIN_APPROVAL=true
ADMIN_APPROVER_EMAIL=admin@example.com
# Public URLs – update after deploying:
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000

# ── SMTP (optional – approval/plan-selection emails) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=IELTS Platform <your_email@gmail.com>

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Set to your Render backend URL after deploying, e.g.:
# VITE_API_URL=https://your-backend.onrender.com/api
# Leave empty to use the Vite dev-server proxy locally.
VITE_API_URL=
