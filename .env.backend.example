# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ielts_db

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Environment
FLASK_ENV=production
FLASK_DEBUG=0

# Server
PORT=5000

# Frontend URL (for CORS and redirects)
FRONTEND_BASE_URL=https://your-frontend.vercel.app
BACKEND_BASE_URL=https://your-backend.onrender.com

# Email Configuration (for login approvals)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com
ADMIN_APPROVER_EMAIL=admin@yourdomain.com
REQUIRE_LOGIN_APPROVAL=true

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
